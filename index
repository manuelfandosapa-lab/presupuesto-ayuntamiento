const TRIENIO_EUR = {A1:660,A2:528,C1:420,C2:312,E:252};
const GRUPO_BADGE = {A1:'b-b',A2:'b-b',C1:'b-g',C2:'b-x',E:'b-x'};

function calcAntiguedad(fi) {
  const [d,m,y] = fi.split('/').map(Number);
  const diff = (new Date(2025,8,1) - new Date(y,m-1,d))/(365.25*24*3600*1000);
  return Math.floor(diff);
}

function calcTrienioEur(emp) {
  return (emp.trienios||0) * (TRIENIO_EUR[emp.grupo]||0);
}

function empRowHTML(e, idx) {
  const av = AVATAR_COLORS[idx % AVATAR_COLORS.length];
  const eur = calcTrienioEur(e);
  const ant = calcAntiguedad(e.fi);
  const mesT = TRIENIO_EUR[e.grupo]||0;
  const proxColor = e.nota.includes('⚠') ? 'c-y' : 'c2';
  const sitBadge = {Activo:'b-g','Baja médica':'b-y',Excedencia:'b-x'}[e.sit]||'b-x';
  const opacity = e.sit==='Excedencia'?'opacity:.5;':e.sit==='Baja médica'?'opacity:.8;':'';
  const args = `'${e.id}','${e.nombre}','${e.ini}','${e.puesto}','${e.cod}','${e.grupo}/${e.nivel}','${e.fi}','${ant} años','${e.trienios}','${e.proxT}','${eur}','${e.partida}','${e.sit}','${e.irpf}','100%','${mesT}'`;
  return `<tr onclick="verEmp(${args})" style="${opacity}">
    <td><div style="display:flex;align-items:center;gap:10px"><div class="avatar" style="background:${av[0]};color:${av[1]}">${e.ini}</div><div><div style="font-weight:700">${e.nombre}</div><div class="mono" style="font-size:10px;color:var(--t3)">${e.id}</div></div></div></td>
    <td><div>${e.puesto}</div><span class="badge ${GRUPO_BADGE[e.grupo]||'b-x'}">${e.grupo}</span></td>
    <td class="mono" style="font-size:12px">${e.fi}</td>
    <td class="mono">${ant} años</td>
    <td>${(()=>{
      if(!e.trienios) return '<span class="c3">—</span>';
      if(e.historial_trienios && e.historial_trienios.length>1){
        return e.historial_trienios.map(h=>`<span class="coste-badge" style="background:var(--purple2);color:var(--purple);border:1px solid rgba(192,144,255,.3);margin-right:3px">${h.num}×${h.mesT}€<span style="font-size:9px;opacity:.7"> ${h.grupo}</span></span>`).join('');
      }
      return `<span class="coste-badge" style="background:var(--purple2);color:var(--purple);border:1px solid rgba(192,144,255,.3)">${e.trienios} × ${mesT} €</span>`;
    })()}</td>
    <td class="mono ${proxColor}">${e.proxT}${e.nota?` <span style="font-size:11px">${e.nota}</span>`:''}</td>
    <td class="mono c-p">${eur>0?fmt(eur)+' €':'—'}</td>
    <td class="mono" style="font-size:11px">${e.partida}</td>
    <td><span class="badge ${sitBadge}">${e.sit}</span></td>
    <td><button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();verEmp(${args})">Ver</button></td>
  </tr>`;
}

function renderEmpleados() {
  const tbody = document.getElementById('emp-tbody');
  if(!tbody) return;
  const rows = EMPLEADOS.map((e,i) => empRowHTML(e,i)).join('');
  tbody.innerHTML = rows;
  const activos = EMPLEADOS.filter(e=>e.sit!=='Excedencia').length;
  const costeTotal = EMPLEADOS.reduce((s,e)=>s+calcTrienioEur(e),0);
  const footer = document.getElementById('emp-footer');
  if(footer) footer.textContent = `Mostrando ${EMPLEADOS.length} empleados · Clic en fila para detalle`;
  const fc = document.getElementById('emp-footer-coste');
  if(fc) fc.textContent = `Coste trienios total: ${fmt(costeTotal)} €/año`;
}

function guardarNuevoEmpleado() {
  const nom = document.getElementById('ne-nombre')?.value?.trim();
  const puesto = document.getElementById('ne-puesto')?.value;
  const fi = document.getElementById('ne-fi')?.value;
  const triStr = document.getElementById('ne-trienios')?.value||'0';
  const irpf = document.getElementById('ne-irpf')?.value||'15';
  const sit = document.getElementById('ne-sit')?.value||'Activo';
  if(!nom||!fi){toast('⚠ Completa nombre y fecha de ingreso','var(--yellow)');return;}
  const nextId = 'EMP-' + String(EMPLEADOS.length+1).padStart(3,'0');
  const ini = nom.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
  // Detect grupo from puesto
  const grupoMap = {
    'F-001':'A1','F-002':'A1','F-003':'A1','F-004':'A1','F-005':'C1',
    'F-006':'C1','F-007':'C2','F-008':'C2','F-009':'C1','F-010':'C1',
    'L-001':'A2','L-002':'A2','L-003':'C2','E-001':'A1'
  };
  const codMatch = puesto.match(/^([A-Z]-\d+)/);
  const cod = codMatch?codMatch[1]:'F-005';
  const grupo = grupoMap[cod]||'C1';
  const nivel = {A1:26,A2:22,C1:20,C2:16,E:20}[grupo]||20;
  const trienios = parseInt(triStr)||0;
  const mesT = TRIENIO_EUR[grupo]||0;
  // Compute prox trienio date
  const [fy,fm,fd] = fi.split('-').map(Number);
  const nextTriDate = new Date(fy+((trienios+1)*3), fm-1, fd);
  const proxT = `${String(nextTriDate.getDate()).padStart(2,'0')}/${String(nextTriDate.getMonth()+1).padStart(2,'0')}/${nextTriDate.getFullYear()}`;
  const fiFormatted = fi.split('-').reverse().join('/');
  EMPLEADOS.push({
    id:nextId, nombre:nom, ini, puesto:puesto.replace(/^[A-Z]-\d+\s·\s/,''),
    cod, grupo, nivel, fi:fiFormatted, trienios, proxT,
    partida: cod.startsWith('L')?'130.00':'120.00',
    sit, irpf:irpf+'%', mesT, nota:''
  });
  renderEmpleados();
  closeM('m-nuevo-emp');
  toast(`✓ Empleado ${nom} dado de alta · ${nextId}`);
  // Scroll to bottom of table
  const tbl = document.getElementById('emp-tbody');
  if(tbl) tbl.lastElementChild?.scrollIntoView({behavior:'smooth',block:'nearest'});
}

