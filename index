// Mes actual (0-indexado)
let MES_ACTUAL = 8;
let VISTA_ANUAL = false;

function getTotalObligado(m) {
  return PARTIDAS.reduce((s,p)=>{
    const pct = p.pct[m];
    return s + (pct !== null ? Math.min(pct,100)/100*p.cred : p.cred);
  },0);
}

function getProyeccionDic(m) {
  // Proyección lineal a diciembre desde el mes actual
  return PARTIDAS.reduce((s,p)=>{
    const pct11 = p.pct[11];
    return s + (pct11 !== null ? pct11/100*p.cred : p.cred);
  },0);
}

function getDeficit(m) {
  // Déficit total = suma de exceso sobre crédito por partida proyectado a dic
  return PARTIDAS.reduce((s,p)=>{
    const pct11 = p.pct[11];
    if (pct11 === null || pct11 <= 100) return s;
    return s + (pct11-100)/100*p.cred;
  },0);
}

function getPartidaRuptura(m) {
  // Primera partida que supere 100% en proyección dic
  for(const p of PARTIDAS){
    const pct11 = p.pct[11];
    if(pct11 !== null && pct11 > 100) return p.cod;
  }
  return null;
}

function getMesRuptura(p) {
  // Mes en que la partida supera 100%
  for(let m=0;m<12;m++){
    if(p.pct[m] !== null && p.pct[m] >= 100) return MESES[m];
  }
  return null;
}

function getCreditoDisponibleBruto(m) {
  const total = getTotalObligado(m);
  const credTot = PARTIDAS.reduce((s,p)=>s+p.cred,0);
  return credTot - total;
}

function getTrieniosRestantes(m) {
  // Trienios Q4 solo aplican a partir de mes 8 (sep) - ya comprometidos
  return m >= 8 ? 1453 : 0;
}

function getCreditoAjustado(m) {
  const bruto = getCreditoDisponibleBruto(m);
  const trienios = getTrieniosRestantes(m);
  const atrasos = m >= 5 ? 12650 : 0; // atrasos se confirman en junio
  const deficit150 = (() => {
    const p150 = PARTIDAS.find(p=>p.cod==='150.00');
    const pct11 = p150.pct[11];
    if(pct11 === null || pct11 <= 100) return 0;
    return (pct11-100)/100*p150.cred;
  })();
  const revision = 5737;
  return bruto - trienios - atrasos - (deficit150 > 0 ? deficit150 : 0) - revision;
}

function getProbDesviacion(m) {
  const deficit = getDeficit(m);
  if(deficit <= 0) return Math.max(5, 10 + m*2);
  const pct150 = PARTIDAS.find(p=>p.cod==='150.00').pct[m];
  if(pct150 === null || pct150 < 70) return 25;
  if(pct150 < 80) return 45;
  if(pct150 < 90) return 68;
  return Math.min(95, 80 + (pct150-90)*1.5);
}

function getNivelRiesgo(m) {
  const pct150 = PARTIDAS.find(p=>p.cod==='150.00').pct[m];
  const deficit = getDeficit(m);
  const totalPct = getTotalObligado(m)/PARTIDAS.reduce((s,p)=>s+p.cred,0)*100;
  const ideal = ((m+1)/12)*100;
  if(pct150 === null || pct150 >= 100 || deficit > 15000) return 'critico';
  if(pct150 >= 85 || deficit > 5000 || totalPct > ideal+8) return 'alerta';
  if(pct150 >= 70 || totalPct > ideal+4) return 'atencion';
  return 'ok';
}

