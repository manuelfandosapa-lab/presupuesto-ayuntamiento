<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>tugesto · Gestión Presupuestaria Cap. I</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#151e2e;--s1:#1c2840;--s2:#223050;--s3:#2a3a60;--s4:#324570;
  --b1:#3d5280;--b2:#4a6298;--b3:#5a74b0;
  --acc:#f59332;--acc2:#ffaa55;--acc3:rgba(245,147,50,0.18);
  --red:#ff5a5a;--red2:rgba(255,90,90,0.20);--red3:rgba(255,90,90,0.10);
  --green:#2eea8a;--green2:rgba(46,234,138,0.18);
  --yellow:#ffd033;--yellow2:rgba(255,208,51,0.18);
  --blue:#60aaff;--blue2:rgba(96,170,255,0.18);
  --purple:#c090ff;--purple2:rgba(192,144,255,0.18);
  --t1:#f4f7ff;--t2:#b8cce8;--t3:#7a98c8;--t4:#4a6090;
  --mono:'JetBrains Mono',monospace;--sans:'Plus Jakarta Sans',sans-serif;
  --r:10px;--sidebar:248px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:var(--sans);background:var(--bg);color:var(--t1);min-height:100vh;display:flex;font-size:15px;line-height:1.55;}
.sidebar{width:var(--sidebar);height:100vh;background:var(--s1);border-right:1px solid var(--b1);display:flex;flex-direction:column;position:fixed;top:0;left:0;z-index:100;overflow:hidden;}
.logo{padding:22px 20px 18px;border-bottom:1px solid var(--b1);}
.logo-top{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.logo-sq{width:34px;height:34px;background:var(--acc);border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:13px;font-weight:700;color:#000;flex-shrink:0;}
.logo-name{font-size:20px;font-weight:800;letter-spacing:-.03em;color:var(--t1);}
.logo-tag{font-family:var(--mono);font-size:11px;color:var(--t3);letter-spacing:.06em;}
.ente{background:var(--s3);border:1px solid var(--b2);border-radius:8px;padding:9px 13px;display:flex;align-items:center;gap:10px;}
.ente-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);flex-shrink:0;}
.ente-name{font-size:13px;font-weight:700;}
.ente-sub{font-family:var(--mono);font-size:11px;color:var(--t3);}
.nav{padding:10px 0;flex:1;overflow-y:auto;}
.nav-sec{padding:16px 20px 6px;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--t4);}
.ni{display:flex;align-items:center;gap:10px;padding:9px 20px;cursor:pointer;font-size:14px;font-weight:500;color:var(--t2);transition:all .12s;border-left:2px solid transparent;}
.ni:hover{color:var(--t1);background:rgba(255,255,255,.04);}
.ni.active{color:var(--acc);background:var(--acc3);border-left-color:var(--acc);font-weight:700;}
.nbadge{margin-left:auto;font-family:var(--mono);font-size:10px;padding:2px 6px;border-radius:4px;background:var(--s3);border:1px solid var(--b2);color:var(--t3);}
.nbadge.r{background:var(--red2);border-color:var(--red);color:var(--red);}
.nbadge.y{background:var(--yellow2);border-color:var(--yellow);color:var(--yellow);}
.sidebar-ft{padding:14px 20px;border-top:1px solid var(--b1);}
.sidebar-ft-txt{font-family:var(--mono);font-size:10px;color:var(--t4);line-height:1.8;}
.main{margin-left:var(--sidebar);flex:1;min-height:100vh;}
.topbar{height:56px;background:var(--s1);border-bottom:1px solid var(--b1);display:flex;align-items:center;padding:0 26px;gap:14px;position:sticky;top:0;z-index:50;}
.tb-t{font-size:15px;font-weight:700;flex:1;}
.tb-chip{font-family:var(--mono);font-size:11px;padding:4px 11px;border-radius:5px;}
.tc-acc{color:var(--acc);background:var(--acc3);border:1px solid rgba(245,147,50,.3);}
.tc-red{color:var(--red);background:var(--red2);border:1px solid rgba(255,90,90,.35);}
.btn{font-family:var(--sans);font-size:13px;font-weight:700;padding:7px 16px;border-radius:7px;border:none;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:all .12s;white-space:nowrap;}
.btn-acc{background:var(--acc);color:#000;}
.btn-acc:hover{background:var(--acc2);}
.btn-ghost{background:transparent;color:var(--t2);border:1px solid var(--b2);}
.btn-ghost:hover{color:var(--t1);border-color:var(--b3);background:rgba(255,255,255,.04);}
.btn-red{background:var(--red2);color:var(--red);border:1px solid rgba(255,90,90,.35);}
.btn-green{background:var(--green2);color:var(--green);border:1px solid rgba(46,234,138,.35);}
.btn-sm{padding:5px 11px;font-size:12px;}
.content{padding:24px;}
.view{display:none;}
.view.active{display:block;animation:fadeIn .15s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(3px);}to{opacity:1;transform:translateY(0);}}
.risk-block{background:linear-gradient(135deg,rgba(255,90,90,.14),rgba(255,90,90,.05));border:1px solid rgba(255,90,90,.4);border-radius:12px;padding:24px 26px;margin-bottom:22px;position:relative;overflow:hidden;}
.risk-block::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--red),rgba(255,90,90,.2));}
.risk-label{font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.risk-pulse{width:9px;height:9px;border-radius:50%;background:var(--red);animation:pulse 1.5s ease-in-out infinite;flex-shrink:0;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(255,90,90,.6);}50%{box-shadow:0 0 0 7px rgba(255,90,90,0);}}
.risk-grid{display:grid;grid-template-columns:1fr 1fr 1fr 2fr;gap:18px;}
.risk-stat-lbl{font-family:var(--mono);font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px;}
.risk-stat-val{font-size:30px;font-weight:800;letter-spacing:-.02em;line-height:1;}
.risk-stat-sub{font-size:12px;color:var(--t2);margin-top:5px;}
.risk-actions{background:rgba(0,0,0,.25);border-radius:10px;padding:16px 18px;}
.risk-actions-title{font-family:var(--mono);font-size:10px;color:var(--t3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:12px;}
.risk-action{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.07);cursor:pointer;gap:10px;transition:all .12s;}
.risk-action:last-child{border-bottom:none;}
.risk-action:hover{background:rgba(255,255,255,.04);margin:0 -10px;padding:8px 10px;border-radius:6px;}
.risk-action-txt{font-size:13px;font-weight:500;flex:1;}
.risk-action-impact{font-family:var(--mono);font-size:12px;font-weight:700;}
.risk-action-btn{background:rgba(255,255,255,.09);border:1px solid var(--b2);border-radius:5px;padding:4px 10px;font-size:12px;font-family:var(--sans);font-weight:600;color:var(--t2);cursor:pointer;white-space:nowrap;transition:all .12s;}
.risk-action-btn:hover{background:var(--acc3);color:var(--acc);border-color:rgba(245,147,50,.4);}
.kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:22px;}
.kpi{background:var(--s2);border:1px solid var(--b1);border-radius:var(--r);padding:18px;position:relative;overflow:hidden;}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--kc,var(--b2));}
.kpi-lbl{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--t3);margin-bottom:9px;}
.kpi-val{font-size:24px;font-weight:800;letter-spacing:-.02em;line-height:1;}
.kpi-sub{font-size:12px;color:var(--t2);margin-top:5px;}
.kpi-delta{display:inline-flex;align-items:center;gap:4px;font-family:var(--mono);font-size:11px;padding:3px 7px;border-radius:4px;margin-top:8px;}
.kd-r{background:var(--red2);color:var(--red);}
.kd-g{background:var(--green2);color:var(--green);}
.kd-y{background:var(--yellow2);color:var(--yellow);}
.kd-b{background:var(--blue2);color:var(--blue);}
.credito-ajustado{background:var(--s2);border:1px solid var(--b1);border-radius:var(--r);padding:20px 22px;margin-bottom:18px;}
.ca-title{font-size:14px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.ca-row{display:flex;align-items:center;padding:9px 0;border-bottom:1px solid var(--b1);}
.ca-row:last-child{border-bottom:none;}
.ca-desc{flex:1;font-size:13px;color:var(--t1);}
.ca-desc-sub{font-size:11px;color:var(--t3);margin-top:2px;}
.ca-amount{font-family:var(--mono);font-size:14px;font-weight:700;min-width:110px;text-align:right;}
.ca-bar-wrap{width:100px;margin:0 14px;}
.ca-bar{height:6px;border-radius:3px;}
.ca-total{background:var(--s3);border-radius:8px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;margin-top:12px;}
.ca-semaforo{width:14px;height:14px;border-radius:50%;margin-right:12px;flex-shrink:0;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;margin-bottom:18px;}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:14px;margin-bottom:18px;}
.card{background:var(--s2);border:1px solid var(--b1);border-radius:var(--r);overflow:hidden;margin-bottom:18px;}
.card-hd{padding:14px 20px;border-bottom:1px solid var(--b1);display:flex;align-items:center;gap:12px;}
.card-t{font-size:15px;font-weight:700;flex:1;}
.card-acts{display:flex;gap:10px;align-items:center;}
.tbl-scroll{overflow-x:auto;overflow-y:auto;max-height:520px;}
table{width:100%;border-collapse:collapse;}
th{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--t2);padding:11px 18px;text-align:left;border-bottom:1px solid var(--b1);background:var(--s3);position:sticky;top:0;z-index:2;white-space:nowrap;}
td{padding:12px 18px;font-size:14px;border-bottom:1px solid var(--b1);vertical-align:middle;color:var(--t1);}
tr:last-child td{border-bottom:none;}
tbody tr{cursor:pointer;}
tbody tr:hover td{background:rgba(255,255,255,.03);}
.tr-total td{background:rgba(245,147,50,.06);font-weight:700;}
.badge{font-family:var(--mono);font-size:11px;font-weight:700;padding:3px 8px;border-radius:4px;display:inline-block;white-space:nowrap;}
.b-r{background:var(--red2);color:var(--red);border:1px solid rgba(255,90,90,.35);}
.b-g{background:var(--green2);color:var(--green);border:1px solid rgba(46,234,138,.35);}
.b-y{background:var(--yellow2);color:var(--yellow);border:1px solid rgba(255,208,51,.35);}
.b-b{background:var(--blue2);color:var(--blue);border:1px solid rgba(96,170,255,.35);}
.b-p{background:var(--purple2);color:var(--purple);border:1px solid rgba(192,144,255,.35);}
.b-a{background:var(--acc3);color:var(--acc);border:1px solid rgba(245,147,50,.35);}
.b-x{background:var(--s3);color:var(--t2);border:1px solid var(--b2);}
.prog{background:var(--s3);border-radius:4px;height:6px;}
.prog-fill{height:6px;border-radius:4px;}
.pr{background:var(--red);}
.py{background:var(--yellow);}
.pg{background:var(--green);}
.pa{background:var(--acc);}
.mono{font-family:var(--mono);}
.c-r{color:var(--red);}
.c-g{color:var(--green);}
.c-y{color:var(--yellow);}
.c-a{color:var(--acc);}
.c-p{color:var(--purple);}
.c-b{color:var(--blue);}
.c2{color:var(--t2);}
.c3{color:var(--t3);}
.alert{border-radius:8px;padding:13px 16px;margin-bottom:14px;display:flex;align-items:flex-start;gap:12px;font-size:14px;border-left:3px solid;line-height:1.55;}
.alert-body{flex:1;}
.alert-actions{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}
.al-r{background:var(--red3);border-color:var(--red);color:#ffaaaa;}
.al-y{background:var(--yellow2);border-color:var(--yellow);color:#ffe680;}
.al-g{background:var(--green2);border-color:var(--green);color:#a0ffcc;}
.al-b{background:var(--blue2);border-color:var(--blue);color:#a8d8ff;}
.al-a{background:var(--acc3);border-color:var(--acc);color:var(--acc2);}
.a-btn{background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.2);border-radius:5px;padding:5px 12px;font-size:12px;font-family:var(--sans);font-weight:700;cursor:pointer;color:inherit;transition:all .12s;}
.a-btn:hover{background:rgba(0,0,0,.55);}
.chart-wrap{padding:10px 16px 24px;display:flex;align-items:flex-end;gap:4px;height:150px;overflow:visible;}
.cbar{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;position:relative;}
.cbar-lbl{font-family:var(--mono);font-size:10px;color:var(--t3);}
.chart-leg{display:flex;gap:16px;padding:0 18px 14px;}
.leg{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2);}
.leg-dot{width:9px;height:9px;border-radius:3px;}
.sim-hd{padding:18px 22px;border-bottom:1px solid var(--b1);background:linear-gradient(135deg,rgba(245,147,50,.1),rgba(0,0,0,0));display:flex;align-items:center;gap:12px;}
.sim-title{font-size:16px;font-weight:800;flex:1;}
.sim-body{padding:22px;display:grid;grid-template-columns:1fr 1fr;gap:22px;}
.sim-ctrl{margin-bottom:18px;}
.sim-ctrl-lbl{font-size:13px;font-weight:600;color:var(--t1);margin-bottom:9px;display:flex;justify-content:space-between;}
.sim-ctrl-val{font-family:var(--mono);font-size:13px;color:var(--acc);font-weight:700;}
.sim-range{width:100%;accent-color:var(--acc);cursor:pointer;height:5px;border-radius:3px;}
.sim-toggle{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--b1);}
.sim-toggle:last-child{border-bottom:none;}
.sim-toggle-lbl{font-size:14px;color:var(--t1);}
.toggle-sw{position:relative;width:38px;height:22px;cursor:pointer;}
.toggle-sw input{opacity:0;width:0;height:0;}
.toggle-track{position:absolute;inset:0;background:var(--b2);border-radius:11px;transition:.2s;}
.toggle-track::before{content:'';position:absolute;left:3px;top:3px;width:16px;height:16px;border-radius:50%;background:var(--t3);transition:.2s;}
.toggle-sw input:checked+.toggle-track{background:var(--acc);}
.toggle-sw input:checked+.toggle-track::before{transform:translateX(16px);background:#000;}
.sim-results{background:var(--s3);border-radius:10px;padding:20px;}
.sim-res-item{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--b1);}
.sim-res-item:last-child{border-bottom:none;}
.sim-res-lbl{font-size:14px;color:var(--t2);}
.sim-res-val{font-family:var(--mono);font-size:15px;font-weight:700;}
.sim-ruptura{margin-top:14px;padding:14px;background:rgba(0,0,0,.3);border-radius:8px;text-align:center;}
.sim-ruptura-lbl{font-family:var(--mono);font-size:10px;color:var(--t3);margin-bottom:6px;text-transform:uppercase;letter-spacing:.1em;}
.sim-ruptura-val{font-size:24px;font-weight:800;}
.proy-escenarios{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.proy-esc{background:var(--s3);border-radius:8px;padding:14px;text-align:center;}
.proy-esc-lbl{font-family:var(--mono);font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:7px;}
.proy-esc-val{font-size:18px;font-weight:800;}
.proy-esc-sub{font-size:12px;color:var(--t2);margin-top:4px;}
.ig-hd{background:linear-gradient(135deg,rgba(96,170,255,.12),rgba(0,0,0,0));padding:18px 22px;border-bottom:1px solid var(--b1);display:flex;align-items:center;gap:12px;}
.ig-doc{background:var(--s3);border:1px solid var(--b2);border-radius:10px;padding:22px;font-size:13px;line-height:1.9;color:var(--t2);max-height:260px;overflow-y:auto;}
.ig-doc strong{color:var(--t1);}
.ig-titulo{font-size:16px;font-weight:800;color:var(--t1);margin-bottom:14px;}
.fg{margin-bottom:15px;}
.fg label{display:block;font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--t3);margin-bottom:6px;}
.fi{width:100%;background:var(--s3);border:1px solid var(--b2);border-radius:7px;padding:9px 13px;font-size:14px;color:var(--t1);font-family:var(--sans);outline:none;transition:border-color .12s;}
.fi:focus{border-color:var(--acc);}
.fi::placeholder{color:var(--t4);}
select.fi option{background:var(--s2);color:var(--t1);}
select option{background:var(--s2);color:var(--t1);}
textarea.fi{resize:vertical;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.modal-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.82);z-index:300;align-items:center;justify-content:center;backdrop-filter:blur(5px);}
.modal-ov.open{display:flex;}
.modal{background:var(--s2);border:1px solid var(--b2);border-radius:14px;width:620px;max-height:88vh;overflow-y:auto;box-shadow:0 28px 90px rgba(0,0,0,.7);}
.modal-lg{width:780px;}
.modal-hd{padding:20px 24px;border-bottom:1px solid var(--b1);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--s2);z-index:1;}
.modal-t{font-size:16px;font-weight:700;}
.modal-x{background:none;border:none;color:var(--t3);cursor:pointer;font-size:22px;line-height:1;}
.modal-x:hover{color:var(--t1);}
.modal-body{padding:24px;}
.modal-ft{padding:16px 24px;border-top:1px solid var(--b1);display:flex;justify-content:flex-end;gap:10px;background:var(--s2);position:sticky;bottom:0;}
.search-inp{background:var(--s3);border:1px solid var(--b2);border-radius:7px;padding:8px 13px;font-size:13px;font-family:var(--mono);color:var(--t1);outline:none;width:200px;}
.search-inp:focus{border-color:var(--acc);}
.search-inp::placeholder{color:var(--t4);}
.sec-t{font-size:24px;font-weight:800;letter-spacing:-.02em;color:var(--t1);margin-bottom:4px;}
.sec-sub{font-size:13px;color:var(--t2);margin-bottom:20px;}
.avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;flex-shrink:0;}

.view-header{display:flex;align-items:center;gap:14px;margin-bottom:6px;}
.back-btn{display:inline-flex;align-items:center;gap:6px;background:var(--s3);border:1px solid var(--b2);border-radius:7px;padding:6px 13px;font-size:13px;font-weight:600;color:var(--t2);cursor:pointer;transition:all .12s;white-space:nowrap;font-family:var(--sans);}
.back-btn:hover{background:var(--b1);color:var(--t1);border-color:var(--b3);}

.narrative{font-size:14px;line-height:1.75;color:var(--t2);background:var(--s3);border-radius:10px;padding:18px 20px;border-left:4px solid var(--acc);margin-bottom:18px;}
.narrative strong{color:var(--t1);}
.bloqueo-row{display:flex;align-items:center;gap:14px;padding:12px 18px;border-bottom:1px solid var(--b1);}
.bloqueo-row:last-child{border-bottom:none;}
.coste-badge{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:11px;font-weight:700;padding:3px 9px;border-radius:4px;}

/* ── PASSWORD OVERLAY ─────────────────────────────────── */
#pw-overlay{position:fixed;inset:0;z-index:9999;background:var(--bg);
  display:flex;align-items:center;justify-content:center;flex-direction:column;}
#pw-overlay.hidden{display:none;}
.pw-box{background:var(--s1);border:1px solid var(--b1);border-radius:16px;
  padding:48px 44px;width:380px;text-align:center;box-shadow:0 24px 64px rgba(0,0,0,.5);}
.pw-logo{font-family:var(--sans);font-size:22px;font-weight:800;color:var(--acc);
  letter-spacing:-.01em;margin-bottom:4px;}
.pw-sub{font-size:12px;color:var(--t3);margin-bottom:32px;font-family:var(--mono);}
.pw-title{font-size:15px;font-weight:600;color:var(--t1);margin-bottom:6px;}
.pw-hint{font-size:11px;color:var(--t3);margin-bottom:20px;}
