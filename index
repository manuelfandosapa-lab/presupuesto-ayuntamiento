        <div style="position:absolute;bottom:0;left:0;right:0;height:${tri/maxVal*100}%;background:var(--purple);opacity:.7"></div>
        ${isCurrent?`<div style="position:absolute;top:-18px;left:50%;transform:translateX(-50%);font-family:var(--mono);font-size:8px;color:var(--acc);white-space:nowrap">◆</div>`:''}
      </div>
      <div class="cbar-lbl" style="${isCurrent?'color:var(--acc);font-weight:700':''}">${lbl}</div>
    </div>`;
  }).join('');
}

function buildProyChart(m) {
  const c = document.getElementById('chart-proy-wrap');
  if(!c) return;
  const deficit = getDeficit(m);
  const base = deficit > 0 ? deficit/2 : 5000;
  const sc = [
    {l:'Peor caso', v:-Math.round(deficit||17290), col:'var(--red)'},
    {l:'Escenario base', v:Math.round(deficit>0?base:8650), col:'var(--yellow)'},
    {l:'Óptimo', v:Math.round(deficit>0?deficit+20000:38200), col:'var(--green)'},
  ];
  const maxAbs = Math.max(...sc.map(s=>Math.abs(s.v)));
  c.innerHTML=`<div style="display:flex;gap:20px;align-items:flex-end;height:90px">${sc.map(s=>`<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px"><div style="font-family:var(--mono);font-size:10px;color:${s.col};font-weight:700">${s.v>0?'+':''}${fmt(Math.abs(s.v))} €</div><div style="width:100%;height:${Math.max(8,Math.abs(s.v)/maxAbs*70)}px;background:${s.col};opacity:.7;border-radius:4px 4px 0 0"></div><div style="font-family:var(--mono);font-size:9px;color:var(--t3);text-align:center">${s.l}</div></div>`).join('')}</div>`;
}

function buildTablaPartidas(m) {
  const t = document.getElementById('tabla-partidas-dash');
  if(!t) return;
  const rows = PARTIDAS.map(p=>{
    const pct = p.pct[m];
    const pctVal = pct===null?100:pct;
    const pct11 = p.pct[11];
    const st = pctVal>=100?'r':pctVal>=85?'r':pctVal>=75?'y':'g';
    const lbl = pctVal>=100?'AGOTADA':pctVal>=85?'ALERTA':pctVal>=75?'ATENCIÓN':'OK';
    const barCol = {r:'var(--red)',y:'var(--yellow)',g:'var(--green)'}[st];
    const isMain = p.cod==='150.00'&&pctVal>=80;
    return `<tr style="${isMain?'background:rgba(255,85,85,.04);':''}">
      <td class="mono" style="${st==='r'?'color:var(--red);':''}">${p.cod}</td>
      <td style="font-size:12px">${p.desc}</td>
      <td><div class="prog"><div class="prog-fill" style="width:${Math.min(pctVal,100)}%;background:${barCol};height:4px;border-radius:3px"></div></div><span class="mono" style="font-size:11px;color:${barCol}">${pct===null?'—':pctVal+'%'}</span></td>
      <td><span class="badge b-${st}">${lbl}</span></td>
    </tr>`;
  });
  t.innerHTML=`<table><thead><tr><th>Partida</th><th>Descripción</th><th>Ejec. ${MESES[m]}</th><th>Estado</th></tr></thead><tbody>${rows.join('')}</tbody></table>`;
}
function updateSim(){
  const emp=parseInt(document.getElementById('si-emp').value);
  const sal=parseFloat(document.getElementById('si-sal').value);
  const v1=document.getElementById('si-v1').checked;
  const v2=document.getElementById('si-v2').checked;
  const tri=document.getElementById('si-tri').checked;
  const atr=document.getElementById('si-atr').checked;
  const mod=parseInt(document.getElementById('si-mod').value);
  const res=document.getElementById('si-res').checked;
  document.getElementById('sv-emp').textContent=emp;
  document.getElementById('sv-sal').textContent=sal.toFixed(1)+'%';
  document.getElementById('sv-mod').textContent=mod.toLocaleString('es-ES')+' €';
  const base=317910;
  const gastoBase=298470;
  const dEmp=(emp-39)*2800;
  const dSal=97860*(sal/100)*3;
  const dV1=v1?-4050:0;
  const dV2=v2?-3683:0;
  const dAtr=atr?12650:0;
  const dRes=res?5200:0;
  const credito=base+mod+(tri?0:1453)+(atr?0:12650);
  const gasto=gastoBase+dEmp+dSal+dV1+dV2+(atr?12650:0)-(res?5200:0);
  const resultado=credito-gasto;
  const mensual=97860+(dEmp/3)+(97860*sal/100);
  const f=v=>document.getElementById(v);
  f('sr-credito').textContent=Math.round(credito).toLocaleString('es-ES')+' €';
  f('sr-credito').style.color=credito>310000?'var(--green)':credito>285000?'var(--yellow)':'var(--red)';
  f('sr-gasto').textContent=Math.round(gasto).toLocaleString('es-ES')+' €';
  f('sr-res').textContent=(resultado>=0?'+':'')+Math.round(resultado).toLocaleString('es-ES')+' €';
  f('sr-res').style.color=resultado>=0?'var(--green)':resultado>-5000?'var(--yellow)':'var(--red)';
  f('sr-men').textContent=Math.round(mensual).toLocaleString('es-ES')+' €';
  f('sr-tri').textContent=tri?'−1.453 €':'0 €';
  f('sr-atr').textContent=atr?'−12.650 €':'0 €';
  const ok=resultado>=0||mod>=8400;
  f('sr-ruptura').textContent=ok?'Sin ruptura':'Octubre 2025';
  f('sr-ruptura').style.color=ok?'var(--green)':'var(--red)';
  f('sr-ruptdet').textContent=ok?'Cierre en positivo con este escenario':'Partida 150.00 · semana 2';
  const prob=Math.min(95,Math.max(5,13+(resultado/800)+(mod/100)+(res?15:0)));
  f('sr-prob').textContent=Math.round(prob)+'%';
  f('sr-prob-bar').style.width=prob+'%';
  f('sr-prob-bar').style.background=prob>70?'var(--green)':prob>40?'var(--yellow)':'var(--red)';
}

function resetSim(){['si-emp','si-sal','si-mod'].forEach(id=>document.getElementById(id).value=id==='si-emp'?39:id==='si-sal'?0:0);['si-v1','si-v2','si-atr','si-res'].forEach(id=>document.getElementById(id).checked=false);document.getElementById('si-tri').checked=true;updateSim();}

// Ver empleado
function verEmp(id,nom,ini,puesto,cod,grupo,fi,ant,t,proxT,costeT,partida,sit,irpf,jornada,mesT){
  document.getElementById('demp-title').textContent=nom+' · '+id+' · '+cod;
  document.getElementById('demp-puesto').textContent=puesto+' · '+grupo;
  const sc={Activo:'var(--green)','Baja médica':'var(--yellow)',Excedencia:'var(--t3)'}[sit]||'var(--t3)';
  document.getElementById('demp-sit').innerHTML=`<span style="display:inline-block;padding:2px 8px;border-radius:3px;border:1px solid ${sc};color:${sc};font-family:var(--mono);font-size:10px">${sit}</span>`;
  document.getElementById('demp-jornada').textContent=jornada+' jornada · IRPF '+irpf;
  document.getElementById('demp-fi').textContent=fi;
  document.getElementById('demp-ant').textContent=ant;
  // Buscar datos completos del empleado (con historial_trienios)
  const empData = EMPLEADOS.find(e=>e.id===id);
  const historial = empData && empData.historial_trienios ? empData.historial_trienios : [{grupo:grupo,num:parseInt(t),mesT:parseInt(mesT)}];
  const totalTriMes = historial.reduce((s,h)=>s+(h.num*h.mesT),0);
  const totalTriAnio = totalTriMes * 14;
  document.getElementById('demp-trienios').textContent=t+' trienios · '+totalTriAnio.toLocaleString('es-ES')+' €/año · '+partida;
  const base={'55':1337,'44':1084,'35':858,'26':707,'21':602}[mesT]||858;
  // Filas de trienios desglosadas por grupo
  const triRows = historial.map(h=>`
    <tr style="color:var(--purple)">
      <td>Trienios Grupo ${h.grupo} (${h.num} × ${h.mesT} €/mes)</td>
      <td class="mono c-p">${(h.num*h.mesT).toLocaleString('es-ES')} €</td>
    </tr>`).join('');
  const triNote = historial.length > 1
    ? `<tr style="font-size:11px"><td colspan="2" style="color:var(--t3);font-style:italic;padding-top:2px">⚠ Cada trienio se paga a la cuantía del grupo en que consolidó (LPGE)</td></tr>`
    : '';
  document.getElementById('demp-retrib').innerHTML=`<table><thead><tr><th>Concepto</th><th>€/mes</th></tr></thead><tbody>
    <tr><td>Sueldo base</td><td class="mono">${base.toLocaleString('es-ES')} €</td></tr>
    <tr><td>Complementos (según RPT)</td><td class="mono c2">—</td></tr>
    ${triRows}${triNote}
    <tr><td><b>Total trienios</b></td><td class="mono c-p"><b>${totalTriMes.toLocaleString('es-ES')} €</b></td></tr>
    <tr><td>Retención IRPF estimada</td><td class="mono c-r">${irpf}</td></tr>
  </tbody></table>`;
  openM('m-detalle-emp');
}

